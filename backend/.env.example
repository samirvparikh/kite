# Copy to .env and fill in from https://developers.kite.trade/
API_KEY=
API_SECRET=
# Optional: defaults to http://127.0.0.1:5173/callback in dev; use https://inningstar.com/callback in production
REDIRECT_URL=http://127.0.0.1:5173/callback
# Optional: Node listen port (default 5000)
# PORT=5000

# App login auth token secret
JWT_SECRET=1c7f1e2d9b4a6f3c5d1e1a7b9c2f4d6e1a1b3c5d7e9f2a4b6c1d1e3f5a7b9c2
# Optional token TTL (default 7d)
# AUTH_TOKEN_TTL=7d

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trading
